{
  "env": {
    "node": true,
    "es2021": true,
    "mocha": true
  },
  "extends": ["eslint:recommended", "plugin:prettier/recommended"],
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "rules": {
    "no-console": 0,
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "prefer-const": "error"
  },
  "overrides": [
    {
      "files": ["views/assets/js/**/*.js"],
      "env": {
        "browser": true
      },
      "globals": {
        "$": "readonly",
        "io": "readonly",
        "window": "readonly",
        "document": "readonly",
        "alert": "readonly",
        "playerInfo": "readonly"
      }
    }
    ,
    {
      "files": ["test/**/*.js"],
      "env": {
        "mocha": true
      },
      "rules": {
        "no-unused-vars": "off"
      }
    }
  ]
}

