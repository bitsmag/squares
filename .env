########################################
# Core node-app configuration
########################################

# Public HTTP port for the Node server
PORT=3000

# Internal URL for the bot server inside the Docker network
# (must point at the bot-server service name and port 8000)
BOT_SERVER_URL=http://bot-server:8000/act


########################################
# RL training configuration (Node backend)
#
# These are only used when the RL training endpoints (/rl/reset, /rl/step)
# are called by the Python training script. They do not affect normal
# human-vs-human gameplay.
########################################

# Probability [0,1] that a training episode will include bot opponents
# when the external bot server is reachable. The remaining episodes are solo.
# 0.0 = always solo, 1.0 = always with opponents.
RL_TRAIN_OPPONENT_PROB=0.7

# Reward shaping: extra reward per newly claimed square.
# Higher = stronger push to paint new territory.
# RL_REWARD_NEW_SQUARE_BONUS=0.1

# Reward shaping: base penalty applied for idle steps (no new squares,
# no score change). The effective penalty scales with an "idle streak"
# counter and is capped by RL_REWARD_MAX_IDLE_PENALTY.
# RL_REWARD_IDLE_PENALTY=-0.05

# Reward shaping: cap (most negative value) for the idle penalty applied
# when the agent stays idle for many consecutive steps.
# RL_REWARD_MAX_IDLE_PENALTY=-0.5

# Reward shaping: one-time bonus when the agent picks up a new
# double-speed special.
# RL_REWARD_DOUBLE_SPEED_BONUS=1.0

# Competitive shaping: small per-step bonus proportional to the score
# margin versus the best opponent. Positive when ahead, negative when behind.
# RL_REWARD_MARGIN_FACTOR=0.01

# Terminal win bonus: base reward added on top of the margin shaping
# when the agent wins an episode (has higher score at the end).
# RL_REWARD_WIN_BASE_BONUS=7

# Terminal win bonus: factor multiplied by the (capped) score margin to
# reward winning by larger margins.
# RL_REWARD_WIN_MARGIN_FACTOR=0.5

# Terminal win bonus: maximum score margin used when scaling the win
# bonus, to prevent extremely large wins from dominating learning.
# RL_REWARD_WIN_MARGIN_CAP=50
