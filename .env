# Environment for node-app service

# Public HTTP port for the Node server
PORT=3000

# Internal URL for the bot server inside the Docker network
# (must point at the bot-server service name and port 8000)
BOT_SERVER_URL=http://bot-server:8000/act

# Optional: probability [0,1] that a training episode (RL-train endpoints)
# will include bot opponents when the bot server is reachable.
# 0.0 = always solo, 1.0 = always with opponents (default 1)
# RL_TRAIN_OPPONENT_PROB=0.8
