# Environment variables for RL training (used by train_ppo.py)
#
# Base URL of the Squares Node server exposing /rl/reset and /rl/step
# SQUARES_BASE_URL=http://localhost:3000
#
# Root directory where per-run training folders will be created
# (each run is stored under runs/<run_name>). Defaults to ./runs
SQUARES_RUNS_DIR=./runs
#
# Optional custom run name. If not set, a timestamp-based name will
# be generated automatically.
# SQUARES_RUN_NAME=my_experiment_name
#
# Optional: path to an existing PPO model .zip and VecNormalize .pkl
# to initialize training from a previous run.
# SQUARES_START_MODEL_PATH=./runs/previous_run/model_final.zip
# SQUARES_START_VECNORM_PATH=./runs/previous_run/vecnormalize_final.pkl
#
# Snapshot frequency (in timesteps) for saving intermediate models
SQUARES_SNAPSHOT_FREQ=200000
#
# PPO hyperparameters (all optional; defaults are the current values in code)
# Total number of environment timesteps to train for
SQUARES_TOTAL_TIMESTEPS=600000
#
# Learning rate for the optimizer (default: 0.0003)
SQUARES_LEARNING_RATE=0.1
#
# Number of steps to run per environment per rollout
# (higher = more on-policy data per update, but more memory)
SQUARES_N_STEPS=2048
#
# Mini-batch size for each PPO update
SQUARES_BATCH_SIZE=512
#
# Discount factor (how far into the future rewards matter)
SQUARES_GAMMA=0.995
#
# GAE(lambda) parameter for advantage estimation
SQUARES_GAE_LAMBDA=0.95
#
# PPO clipping range
SQUARES_CLIP_RANGE=0.2
#
# Entropy coefficient (encourages exploration)
SQUARES_ENT_COEF=0.04
#
# Value function loss coefficient
SQUARES_VF_COEF=0.5
#
# Gradient clipping norm
SQUARES_MAX_GRAD_NORM=0.5
