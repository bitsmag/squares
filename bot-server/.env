# Environment for bot-server service

# Required model for bot id 1
BOT_MODEL_1_PATH=models/003b_sometimes-one-opponent/step1200000/ppo_squares.zip

# Optional model for bot id 2 (falls back to bot 1 if missing)
BOT_MODEL_2_PATH=models/002_one-opponent/ppo_squares.zip

# Optional models for bot ids 3 and 4 (each falls back to bot 1 if missing)
#BOT_MODEL_3_PATH=models/001_no-opponent/ppo_squares.zip
# BOT_MODEL_4_PATH=models/004_some-bot/ppo_squares.zip

# Optional VecNormalize stats for each bot id
# If not set, defaults to <model_base>_vecnormalize.pkl when present.
# BOT_VECNORM_1_PATH=models/001_no-opponent/ppo_squares_vecnormalize.pkl
# BOT_VECNORM_2_PATH=models/002_one-opponent/ppo_squares_vecnormalize.pkl
# BOT_VECNORM_3_PATH=models/003_some-bot/ppo_squares_vecnormalize.pkl
# BOT_VECNORM_4_PATH=models/004_some-bot/ppo_squares_vecnormalize.pkl
