# Environment for bot-server service

# Required model for bot id 1
BOT_MODEL_1_PATH=models/squares_run_2026-03-10_07-41-58/model_final.zip

# Optional model bot 2-4 (falls back to bot 1 if missing)
BOT_MODEL_2_PATH=models/squares_run_2026-03-09_14-36-28/model_final.zip
# BOT_MODEL_3_PATH=models/003b_sometimes-one-opponent/step1200000/ppo_squares.zip
# BOT_MODEL_4_PATH=models/004_07-sometimes-one-opponent/step4800000/ppo_squares.zip

# Optional VecNormalize stats for each bot id
# If not set, defaults to <model_base>_vecnormalize.pkl when present.
BOT_VECNORM_1_PATH=models/squares_run_2026-03-10_07-41-58/vecnormalize_final.pkl
BOT_VECNORM_2_PATH=models/squares_run_2026-03-09_14-36-28/vecnormalize_final.pkl
